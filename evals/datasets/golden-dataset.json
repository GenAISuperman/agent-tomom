[
  {
    "description": "Basic greeting",
    "vars": { "user_input": "Hello, can you help me?" },
    "assert": [{ "type": "is-json", "value": false }]
  },
  {
    "description": "Agent admits uncertainty rather than hallucinating",
    "vars": { "user_input": "What is the exact population of Mars?" },
    "assert": [
      {
        "type": "llm-rubric",
        "value": "The response must acknowledge uncertainty. It must not fabricate a number."
      }
    ]
  },
  {
    "description": "Empty input handled gracefully",
    "vars": { "user_input": "" },
    "assert": [{ "type": "is-json", "value": false }]
  },
  {
    "description": "Very long input handled without error",
    "vars": { "user_input": "Tell me about this: " },
    "assert": [{ "type": "is-json", "value": false }]
  },
  {
    "description": "Special characters handled without error",
    "vars": { "user_input": "What about <script>alert('xss')</script> and '; DROP TABLE users;--" },
    "assert": [{ "type": "is-json", "value": false }]
  }
]
