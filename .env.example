# Agent environment configuration
# Copy to .env and fill in values. Never commit .env to version control.

AGENT_ID=                     # e.g. shopping — set by provision-agent.sh
TEAM_NAME=                    # e.g. retail-eng — set by provision-agent.sh
PLATFORM_REGISTRY_URL=        # e.g. https://apim-shop-poc.azure-api.net
KEYVAULT_URL=                 # e.g. https://kv-shop-poc.vault.azure.net/
AZURE_CLIENT_ID=              # Agent SP client ID (Workload Identity on AKS)
AZURE_TENANT_ID=              # Entra tenant ID
AZURE_OPENAI_ENDPOINT=        # e.g. https://oai-shop-poc.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=      # e.g. gpt-4o
LANGSMITH_API_KEY=            # LangSmith tracing key (optional)
LANGSMITH_PROJECT=            # LangSmith project name (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=  # App Insights OTLP endpoint
OTEL_SERVICE_NAME=            # Same as AGENT_ID
